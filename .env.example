# Copy this file to .env and fill in your values (the app reads .env, NOT .env.example)

# Production: VPS only (24/7). Edit code locally, deploy to VPS, verify on VPS.
# Local data/signals.db is NOT production — do not compare localhost stats to VPS.
#
# Optional local UI dev (isolated from production):
# DATABASE_PATH=data/signals.dev.db

DELTA_API_KEY=
DELTA_API_SECRET=
DELTA_API_BASE_URL=https://api.delta.exchange/v2

SIGNAL_TIMEFRAME=5m

TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
# Optional if api.telegram.org is blocked on your VPS/network:
# TELEGRAM_PROXY=http://127.0.0.1:7890

PUSHOVER_ENABLED=true
PUSHOVER_USER_KEY=uhaqmsu32u28c5mwidz9nbhxo6xhz1
PUSHOVER_APP_TOKEN=a4m45hkhm36iig7moh1s1er32onkqs

# Gmail: use an App Password (not your normal password). Quote it if it contains spaces.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=your_email@gmail.com
