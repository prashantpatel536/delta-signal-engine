[Unit]
Description=Delta Signal Engine (FastAPI)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/delta-signal-engine
EnvironmentFile=-/root/delta-signal-engine/.env
ExecStart=/root/delta-signal-engine/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
